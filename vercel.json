{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "ereboros.com" }],
      "destination": "https://www.ereboros.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(js|css|webp|jpg|jpeg|png|svg|ico|woff|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
